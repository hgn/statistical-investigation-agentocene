__pycache__/
*.pyc
.mypy_cache/
.pytest_cache/
.venv/
venv/

# Collected data: never commit. Regenerate via `make get-data`.
data/raw-cache/*
data/records/*
data/panels/*
data/results/*
!data/raw-cache/.gitkeep
!data/records/.gitkeep
!data/panels/.gitkeep
!data/results/.gitkeep

# Claude Code local settings
.claude/settings.local.json
.claude/*.tmp.*

# Secrets: never commit.
.github-token
.gitlab-token
*.token
